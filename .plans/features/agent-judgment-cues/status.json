  "decisions": [
    {
      "id": "D1",
      "choice": "Use deterministic action-class risk metadata instead of model-authored review text",
      "rationale": "The same risk tags need to drive harness behavior, queued actions, and UI copy without prompt drift."
    },
    {
      "id": "D2",
      "choice": "Refine existing Roost and Nest cards instead of adding new review surfaces",
      "rationale": "The product already had the right boundaries; the problem was visibility, not missing screens."
    },
    {
      "id": "D3",
      "choice": "Require explicit acknowledgement only for live, permission, destructive, and permanent-record risks",
      "rationale": "Low-risk work should stay passive while high-stakes and permanent public-record actions pull the human back into the loop."
    }
  ],
  "updated_at": "2026-04-20"
